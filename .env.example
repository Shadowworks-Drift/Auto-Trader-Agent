# Copy to .env and fill in values.
# These override config/config.yaml.

# LLM
AUTO_TRADER_LLM_MODEL=deepseek-r1:7b
AUTO_TRADER_LLM_BASE_URL=http://localhost:11434

# Exchange (only needed for live trading)
AUTO_TRADER_EXCHANGE_API_KEY=
AUTO_TRADER_EXCHANGE_API_SECRET=

# Data
AUTO_TRADER_DATA_NEWS_API_KEY=

# Trading mode
AUTO_TRADER_TRADING_MODE=paper
